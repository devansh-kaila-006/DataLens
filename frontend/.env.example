# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Railway Services URLs (will be generated after deployment)
VITE_RAILWAY_DATA_PROCESSOR_URL=
VITE_RAILWAY_AI_INSIGHTS_URL=
VITE_RAILWAY_REPORT_GENERATOR_URL=

# Gemini AI Configuration
# NOTE: API key is now managed in Supabase Edge Functions for security
# Set GEMINI_API_KEY and GEMINI_MODEL in Supabase Dashboard → Edge Functions → Environment Variables
VITE_GEMINI_API_KEY=your_gemini_api_key_here
VITE_GEMINI_MODEL=gemini-2.5-pro
VITE_GEMINI_TEMPERATURE=0.7
VITE_GEMINI_MAX_TOKENS=4096
